<!-- Leaflet 지도 라이브러리 (CDN) -->
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css">
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<style>
  * { margin: 0; padding: 0; box-sizing: border-box; }
  html, body { height: 100%; }
  body {
    font-family: "Malgun Gothic", "Apple SD Gothic Neo", sans-serif;
    background: #f0f7f4;
    display: flex; flex-direction: column;
  }

  /* ===== 상단 바 ===== */
  header {
    background: linear-gradient(135deg, #1a7f5a, #2eb086);
    color: #fff;
    padding: 10px 14px;
    box-shadow: 0 2px 6px rgba(0,0,0,.2);
    z-index: 1100;
  }
  .header-top { display: flex; align-items: center; justify-content: space-between; gap: 8px; }
  .logo { font-size: 18px; font-weight: bold; white-space: nowrap; }
  .logo small { font-weight: normal; font-size: 11px; opacity: .85; display: block; }
  .header-icons { display: flex; gap: 8px; }
  .icon-btn {
    background: rgba(255,255,255,.18);
    border: 1px solid rgba(255,255,255,.35);
    color: #fff; border-radius: 10px;
    padding: 6px 10px; font-size: 13px; cursor: pointer;
    transition: background .15s;
    white-space: nowrap;
  }
  .icon-btn:hover { background: rgba(255,255,255,.32); }

  .status-row {
    display: flex; flex-wrap: wrap; gap: 6px 14px;
    margin-top: 8px; font-size: 12.5px;
  }
  .status-item { background: rgba(0,0,0,.15); border-radius: 8px; padding: 4px 8px; }
  .status-item b { color: #ffe27a; }

  .timer-row { display: flex; align-items: center; gap: 10px; margin-top: 8px; }
  #timerDisplay { font-size: 22px; font-weight: bold; font-variant-numeric: tabular-nums; }
  .timer-btn {
    border: none; border-radius: 20px; padding: 8px 18px;
    font-size: 14px; font-weight: bold; cursor: pointer;
  }
  .btn-start { background: #ffd043; color: #4a3b00; }
  .btn-stop { background: #ff6b6b; color: #fff; }

  /* ===== 중앙 지도 ===== */
  #map { flex: 1; min-height: 300px; z-index: 1; }

  /* ===== 하단 바 ===== */
  footer {
    background: #fff;
    border-top: 2px solid #d8ebe2;
    padding: 10px 14px;
    display: flex; align-items: center; justify-content: space-between; gap: 8px;
    z-index: 1100;
  }
  .point-box { font-size: 15px; }
  .point-box b { color: #1a7f5a; font-size: 20px; }
  .footer-icons { display: flex; gap: 8px; }
  .footer-btn {
    border: none; border-radius: 12px; padding: 9px 12px;
    font-size: 13px; font-weight: bold; cursor: pointer;
    display: flex; align-items: center; gap: 5px;
  }
  .btn-shop { background: #2eb086; color: #fff; }
  .btn-rank { background: #4a7de0; color: #fff; }
  .btn-donate { background: #ff8c42; color: #fff; }

  /* ===== 모달 공통 ===== */
  .modal-back {
    position: fixed; inset: 0; background: rgba(0,0,0,.5);
    display: none; align-items: center; justify-content: center;
    z-index: 2000; padding: 16px;
  }
  .modal-back.open { display: flex; }
  .modal {
    background: #fff; border-radius: 14px;
    width: 100%; max-width: 460px; max-height: 85vh;
    overflow-y: auto; padding: 18px;
    box-shadow: 0 10px 30px rgba(0,0,0,.3);
  }
  .modal h2 { font-size: 17px; color: #1a7f5a; margin-bottom: 12px; }
  .modal-close {
    float: right; border: none; background: #eee; border-radius: 50%;
    width: 28px; height: 28px; cursor: pointer; font-size: 14px;
  }

  /* 상점 */
  .cat-tabs { display: flex; gap: 6px; margin-bottom: 12px; flex-wrap: wrap; }
  .cat-tab {
    border: 1px solid #2eb086; background: #fff; color: #2eb086;
    border-radius: 16px; padding: 5px 12px; font-size: 13px; cursor: pointer;
  }
  .cat-tab.active { background: #2eb086; color: #fff; }
  .shop-item {
    display: flex; align-items: center; justify-content: space-between;
    border: 1px solid #e2eee8; border-radius: 10px;
    padding: 10px; margin-bottom: 8px; gap: 8px;
  }
  .shop-item .name { font-size: 14px; font-weight: bold; }
  .shop-item .price { font-size: 14px; color: #1a7f5a; font-weight: bold; }
  .shop-item .real-price { font-size: 11px; color: #999; margin-left: 4px; font-weight: normal; }
  .shop-item .limit { font-size: 11px; color: #b07020; }
  .buy-btn {
    border: none; background: #2eb086; color: #fff;
    border-radius: 8px; padding: 6px 12px; cursor: pointer; font-size: 13px;
    white-space: nowrap;
  }
  .buy-btn:disabled { background: #bbb; cursor: not-allowed; }

  /* 랭킹 */
  .rank-tabs { display: flex; gap: 6px; margin-bottom: 12px; }
  .rank-row {
    display: flex; justify-content: space-between; padding: 8px 10px;
    border-bottom: 1px solid #eee; font-size: 14px;
  }
  .rank-row.me { background: #fff6da; border-radius: 8px; font-weight: bold; }
  .rank-medal { width: 26px; display: inline-block; }
  .bonus-note {
    background: #eef6ff; border-radius: 8px; padding: 8px 10px;
    font-size: 12px; color: #33569c; margin-bottom: 10px; line-height: 1.5;
  }

  /* 파티 */
  .party-card {
    border: 1px solid #e2eee8; border-radius: 10px;
    padding: 10px; margin-bottom: 8px;
    display: flex; justify-content: space-between; align-items: center; gap: 8px;
  }
  .party-card .p-name { font-weight: bold; font-size: 14px; }
  .party-card .p-info { font-size: 12px; color: #777; }
  .party-section-title { font-size: 13px; color: #555; margin: 12px 0 6px; font-weight: bold; }
  .party-create { display: flex; gap: 6px; margin-top: 10px; }
  .party-create input {
    flex: 1; border: 1px solid #ccc; border-radius: 8px; padding: 8px; font-size: 13px;
  }

  /* 인증/후원 */
  .verify-box {
    background: #fff8ec; border: 1px dashed #e0a94f; border-radius: 10px;
    padding: 12px; font-size: 13px; line-height: 1.6; margin-bottom: 10px;
  }
  .primary-btn {
    width: 100%; border: none; background: #1a7f5a; color: #fff;
    border-radius: 10px; padding: 11px; font-size: 15px; font-weight: bold;
    cursor: pointer; margin-top: 8px;
  }
  .primary-btn:disabled { background: #aaa; cursor: not-allowed; }
  .donate-account {
    background: #f4f8f6; border-radius: 10px; padding: 12px;
    font-size: 15px; text-align: center; margin: 10px 0; font-weight: bold;
  }
  .small-input {
    width: 100%; border: 1px solid #ccc; border-radius: 8px; padding: 8px;
    font-size: 13px; margin-top: 6px;
  }
  #photoPreview { max-width: 100%; border-radius: 10px; margin-top: 8px; display: none; }

  /* 안내 토스트 */
  #toast {
    position: fixed; left: 50%; bottom: 90px; transform: translateX(-50%);
    background: rgba(30,30,30,.9); color: #fff; padding: 10px 18px;
    border-radius: 20px; font-size: 13px; display: none; z-index: 3000;
    max-width: 90%; text-align: center;
  }
  .guest-badge {
    background: #ffe27a; color: #5c4a00; border-radius: 8px;
    padding: 2px 7px; font-size: 11px; font-weight: bold;
  }
  #fatalError {
    display: none; position: fixed; inset: 0; z-index: 9999;
    background: #fff; color: #b3261e; padding: 20px;
    font-family: monospace; font-size: 13px; line-height: 1.6;
    overflow: auto; white-space: pre-wrap;
  }
  #fatalError.show { display: block; }
</style>
</head>
<body>

<div id="fatalError"></div>

<!-- ===================== 상단 ===================== -->
<header>
  <div class="header-top">
    <div class="logo"> 제주 가치줍깅 <span class="guest-badge">게스트</span>
      <small>제주를 줍깅하고 포인트 받자!</small>
    </div>
    <div class="header-icons">
      <button class="icon-btn" onclick="openModal('partyModal'); renderParties();">파티</button>
    </div>
  </div>
  <div class="status-row">
    <div class="status-item"> 지역: <b id="zoneName">지도를 눌러 선택</b></div>
    <div class="status-item">시작: <b id="startTimeText">-</b></div>
    <div class="status-item">종료: <b id="endTimeText">-</b></div>
    <div class="status-item">오늘 총 줍깅: <b id="dailyTotalText">00:00:00</b> <span style="opacity:.8">(자정 초기화)</span></div>
  </div>
  <div class="timer-row">
    <div id="timerDisplay">00:00:00</div>
    <button id="timerBtn" class="timer-btn btn-start" onclick="toggleTimer()">▶ 줍깅 시작</button>
  </div>
</header>

<!-- ===================== 중앙: 제주 지도 ===================== -->
<div id="map"></div>

<!-- ===================== 하단 ===================== -->
<footer>
  <div class="point-box"> 내 포인트: <b id="pointText">0</b> P</div>
  <div class="footer-icons">
    <button class="footer-btn btn-shop" onclick="openShop()"> 상점</button>
    <button class="footer-btn btn-rank" onclick="openRanking()"> 랭킹</button>
    <button class="footer-btn btn-donate" onclick="openDonate()"> 후원</button>
  </div>
</footer>

<!-- ===================== 포인트 상점 모달 ===================== -->
<div class="modal-back" id="shopModal">
  <div class="modal">
    <button class="modal-close" onclick="closeModal('shopModal')">✕</button>
    <h2>🛒 포인트 상점</h2>
    <div class="cat-tabs" id="catTabs"></div>
    <div id="shopList"></div>
  </div>
</div>

<!-- ===================== 랭킹 모달 ===================== -->
<div class="modal-back" id="rankModal">
  <div class="modal">
    <button class="modal-close" onclick="closeModal('rankModal')">✕</button>
    <h2> 줍깅 랭킹</h2>
    <div class="bonus-note">
       <b>보너스 포인트</b><br>
      주간 랭킹 1~3위: +300P / +200P / +100P<br>
      월간 랭킹 1~3위: +1000P / +700P / +400P<br>
      (순위권에 들면 랭킹 창을 열 때 자동 지급됩니다)
    </div>
    <div class="rank-tabs" id="rankTabs"></div>
    <div id="rankList"></div>
  </div>
</div>

<!-- ===================== 파티 모달 ===================== -->
<div class="modal-back" id="partyModal">
  <div class="modal">
    <button class="modal-close" onclick="closeModal('partyModal')">✕</button>
    <h2>줍깅 파티</h2>
