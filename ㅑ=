function closeGuestNotice() {
  LS.set("guestNoticeSeen", true);
  closeModal("guestModal");
}

/* ============================================================
   시작
   ============================================================ */
window.addEventListener("load", function() {
  /* 각 초기화 단계를 개별 try/catch로 분리:
     한 단계(예: 지도)가 실패해도 나머지(포인트/타이머 등)는 정상 동작하도록 함 */
  function safe(label, fn) {
    try { fn(); } catch (e) {
      console.error("[" + label + "] 초기화 실패:", e);
      const box = document.getElementById("fatalError");
      box.classList.add("show");
      box.textContent += "[" + label + "] " + e.message + "\n\n";
    }
  }

  safe("지도 초기화", initMap);
  safe("구역 데이터 로드", loadZones);
  safe("포인트 표시", renderPoints);
  safe("오늘 줍깅 시간 표시", renderDaily);
  safe("선택 구역 표시", renderZone);

  safe("타이머 복원", function() {
    /* 새로고침 후에도 진행 중이던 타이머 복원 */
    if (running) {
      document.getElementById("startTimeText").textContent = fmtClock(running);
      const btn = document.getElementById("timerBtn");
      btn.textContent = "■ 줍깅 종료";
      btn.className = "timer-btn btn-stop";
    }
  });

  safe("인증 대기 세션 처리", function() {
    /* 인증 대기 중이던 세션 처리 */
    if (pending) {
      if ((Date.now() - pending.end) / 1000 > 3600) {
        pending = null; LS.set("pending", null);
        toast("이전 활동의 인증 시간이 지나 포인트가 지급되지 않았습니다.");
      } else {
        showPendingButton();
        openVerify();
      }
    }
  });

  safe("게스트 안내 표시", function() {
    /* 첫 방문 게스트 안내 */
    if (!LS.get("guestNoticeSeen", false)) openModal("guestModal");
  });
});
</script>
</body>
</html>
