   (원인 파악용 — 정상 동작 시에는 아무 영향 없음)
   ============================================================ */
window.addEventListener("error", function(e) {
  const box = document.getElementById("fatalError");
  box.classList.add("show");
  box.textContent += "[에러] " + e.message + "\n  at " + (e.filename || "") + ":" + e.lineno + "\n\n";
});
window.addEventListener("unhandledrejection", function(e) {
  const box = document.getElementById("fatalError");
  box.classList.add("show");
  box.textContent += "[Promise 에러] " + (e.reason && e.reason.message ? e.reason.message : e.reason) + "\n\n";
});

