const WEEKLY_BONUS  = [300, 200, 100];
const MONTHLY_BONUS = [1000, 700, 400];

/* 줍깅 시간(분)에 따른 차등 포인트 지급 표 */
function calcPoints(seconds) {
  const min = seconds / 60;
  if (min < 1)  return 5;    // 1분 미만: 참여 포인트
  if (min < 10) return 30;   // 1~10분
  if (min < 30) return 100;  // 10~30분
  if (min < 60) return 250;  // 30~60분
  return 250 + Math.floor((min - 60) / 30) * 100 + 150; // 1시간 이상
}

/* ============================================================
   저장소(localStorage) 도우미
   ============================================================ */
const LS = {
  get(key, def) {
    try {
      const v = localStorage.getItem("jeju_" + key);
      return v === null ? def : JSON.parse(v);
    } catch (e) { return def; }
  },
  set(key, val) { localStorage.setItem("jeju_" + key, JSON.stringify(val)); }
};

function todayStr()  { const d = new Date(); return d.getFullYear() + "-" + (d.getMonth()+1) + "-" + d.getDate(); }
function weekId()    { const d = new Date(); const onejan = new Date(d.getFullYear(),0,1); const w = Math.ceil((((d - onejan) / 86400000) + onejan.getDay() + 1) / 7); return d.getFullYear() + "-W" + w; }
function monthId()   { const d = new Date(); return d.getFullYear() + "-" + (d.getMonth()+1); }
function yearId()    { return String(new Date().getFullYear()); }

function fmtHMS(sec) {
  sec = Math.max(0, Math.floor(sec));
  const h = String(Math.floor(sec/3600)).padStart(2,"0");
  const m = String(Math.floor(sec%3600/60)).padStart(2,"0");
  const s = String(sec%60).padStart(2,"0");
  return h + ":" + m + ":" + s;
}
function fmtClock(ts) {
  const d = new Date(ts);
  return String(d.getHours()).padStart(2,"0") + ":" + String(d.getMinutes()).padStart(2,"0") + ":" + String(d.getSeconds()).padStart(2,"0");
}

/* ============================================================
   전역 상태
   ============================================================ */
let zones = [];
let map, markers = [];
let selectedZone = LS.get("selectedZone", null);
let points = LS.get("points", 0);
let running = LS.get("runningStart", null);   // 타이머 시작 시각(ms) 또는 null
let pending = LS.get("pending", null);        // 인증 대기 세션 { end, dur }
let currentCat = "편의점";
let currentRankTab = "일간";

/* 하루 총 줍깅 시간: 날짜가 바뀌면(자정) 자동 초기화 */
function getDaily() {
  let d = LS.get("daily", { date: todayStr(), sec: 0 });
  if (d.date !== todayStr()) { d = { date: todayStr(), sec: 0 }; LS.set("daily", d); }
  return d;
}
function addDaily(sec) {
  const d = getDaily();
  d.sec += sec;
  LS.set("daily", d);
}

/* 주간/월간/연간 누적 (랭킹용) - 기간 ID가 바뀌면 초기화 */
function getPeriod(kind, idFn) {
  let p = LS.get("period_" + kind, { id: idFn(), sec: 0 });
  if (p.id !== idFn()) { p = { id: idFn(), sec: 0 }; LS.set("period_" + kind, p); }
  return p;
}
function addPeriods(sec) {
  ["week","month","year"].forEach(function(kind) {
    const idFn = kind === "week" ? weekId : kind === "month" ? monthId : yearId;
    const p = getPeriod(kind, idFn);
    p.sec += sec;
    LS.set("period_" + kind, p);
  });
}

/* ============================================================
   화면 갱신
   ============================================================ */
function toast(msg) {
  const t = document.getElementById("toast");
  t.textContent = msg;
  t.style.display = "block";
  clearTimeout(t._tm);
  t._tm = setTimeout(function(){ t.style.display = "none"; }, 2600);
}
function openModal(id)  { document.getElementById(id).classList.add("open"); }
function closeModal(id) { document.getElementById(id).classList.remove("open"); }

function renderPoints() { document.getElementById("pointText").textContent = points.toLocaleString(); }
function renderDaily()  { document.getElementById("dailyTotalText").textContent = fmtHMS(getDaily().sec); }
function renderZone()   { document.getElementById("zoneName").textContent = selectedZone || "지도를 눌러 선택"; }

/* 1초마다: 타이머 표시 + 하루 총 시간 + 인증 남은 시간 */
setInterval(function tick() {
  if (running) {
    document.getElementById("timerDisplay").textContent = fmtHMS((Date.now() - running) / 1000);
  }
  renderDaily();
  if (pending && document.getElementById("verifyModal").classList.contains("open")) {
    const remain = 3600 - (Date.now() - pending.end) / 1000;
    document.getElementById("verifyRemain").textContent = remain > 0 ? fmtHMS(remain) : "만료됨";
  }
}, 1000);

/* ============================================================
   타이머 (줍깅 시작 / 종료)
   ============================================================ */
function toggleTimer() {
  const btn = document.getElementById("timerBtn");
  if (!running) {
    if (pending) { toast("먼저 이전 활동의 인증을 완료하거나 만료를 기다려주세요."); openVerify(); return; }
    running = Date.now();
    LS.set("runningStart", running);
    document.getElementById("startTimeText").textContent = fmtClock(running);
    document.getElementById("endTimeText").textContent = "-";
    btn.textContent = "■ 줍깅 종료";
    btn.className = "timer-btn btn-stop";
    toast("줍깅 시작! " + (selectedZone ? selectedZone + "에서 " : "") + "화이팅");
  } else {
    const end = Date.now();
    const dur = Math.floor((end - running) / 1000);
    document.getElementById("endTimeText").textContent = fmtClock(end);
    running = null;
    LS.set("runningStart", null);
    btn.textContent = " 줍깅 시작";
    btn.className = "timer-btn btn-start";
    document.getElementById("timerDisplay").textContent = "00:00:00";
    pending = { end: end, dur: dur };
    LS.set("pending", pending);
    openVerify();
  }
}

/* ============================================================
   인증 사진 (종료 후 1시간 이내)
   ============================================================ */
function openVerify() {
  if (!pending) return;
  if ((Date.now() - pending.end) / 1000 > 3600) {
    pending = null; LS.set("pending", null);
    toast(" 인증 시간(1시간)이 지나 포인트가 지급되지 않았습니다.");
    return;
  }
  document.getElementById("verifyDuration").textContent = fmtHMS(pending.dur);
  document.getElementById("photoInput").value = "";
  document.getElementById("photoPreview").style.display = "none";
  document.getElementById("verifyBtn").disabled = true;
  openModal("verifyModal");
}
function previewPhoto() {
  const file = document.getElementById("photoInput").files[0];
  if (!file) return;
  const img = document.getElementById("photoPreview");
  img.src = URL.createObjectURL(file);
  img.style.display = "block";
  document.getElementById("verifyBtn").disabled = false;
}
function submitVerification() {
  if (!pending) return;
  if ((Date.now() - pending.end) / 1000 > 3600) {
    pending = null; LS.set("pending", null);
    closeModal("verifyModal");
    toast(" 인증 시간(1시간)이 지나 포인트가 지급되지 않았습니다.");
    return;
  }
  const earned = calcPoints(pending.dur);
  points += earned;
  LS.set("points", points);
  addDaily(pending.dur);
  addPeriods(pending.dur);

  /* 선택한 구역이 있으면 '줍깅 완료'로 표시 (+API 전송 시도) */
  if (selectedZone) {
    const z = zones.find(function(z){ return z.name === selectedZone; });
    if (z && !z.done) {
      z.done = true;
      postToApi({ action: "complete", name: z.name });
      drawMarkers();
    }
  }
  const dur = pending.dur;
  pending = null;
  LS.set("pending", null);
  closeModal("verifyModal");
  toast(" 인증 완료! 줍깅 " + fmtHMS(dur) + " → +" + earned + "P 지급!");
  renderPoints();
}
function cancelVerification() {
  closeModal("verifyModal");
  toast("종료 후 1시간 안에 상단 '인증 대기' 버튼으로 인증해주세요!");
  showPendingButton();
}
function showPendingButton() {
  if (document.getElementById("pendingBtn")) return;
  const btn = document.createElement("button");
  btn.id = "pendingBtn";
  btn.className = "icon-btn";
  btn.textContent = "인증 대기";
  btn.style.background = "#ff8c42";
  btn.onclick = openVerify;
  document.querySelector(".header-icons").prepend(btn);
  const iv = setInterval(function() {
    if (!pending) { btn.remove(); clearInterval(iv); }
  }, 1000);
}

/* ============================================================
   지도 (Leaflet + OpenStreetMap)
   ============================================================ */
function initMap() {
  if (typeof L === "undefined") {
    throw new Error("Leaflet 라이브러리(L)를 불러오지 못했습니다. unpkg.com CDN 접속이 막혀있는지 확인해주세요.");
  }
  map = L.map("map").setView([33.38, 126.55], 10);
  L.tileLayer("https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png", {
    maxZoom: 18,
    subdomains: "abc",
    attribution: "&copy; OpenStreetMap contributors"
  }).addTo(map);
}
function drawMarkers() {
  markers.forEach(function(m){ map.removeLayer(m); });
  markers = [];
  zones.forEach(function(z) {
    const icon = L.divIcon({
      className: "",
      html: '<div style="font-size:26px; text-shadow:0 1px 3px rgba(0,0,0,.4);">' + (z.done ? "✅" : "🗑️") + "</div>",
      iconSize: [26, 26], iconAnchor: [13, 13]
    });
    const m = L.marker([z.lat, z.lng], { icon: icon }).addTo(map);
    m.bindPopup(
      "<b>" + z.name + "</b><br>등록: " + z.regTime +
      "<br>상태: " + (z.done ? "줍깅 완료" : "줍깅 필요") +
      '<br><button style="margin-top:6px; padding:5px 10px; border:none; background:#2eb086; color:#fff; border-radius:6px; cursor:pointer;" onclick="selectZone(\'' + z.name.replace(/'/g, "\\'") + '\')">이 구역 선택</button>'
    );
    markers.push(m);
  });
}
function selectZone(name) {
  selectedZone = name;
  LS.set("selectedZone", name);
  renderZone();
  map.closePopup();
  toast( name + " 선택됨");
}

/* ============================================================
   백엔드 통신 (Apps Script). 실패 시 데모 데이터 사용
   ============================================================ */
async function loadZones() {
  if (API_URL) {
    try {
      const res = await fetch(API_URL);
      const data = await res.json();
      /* 시트 열: 지역 이름 | 위도 | 경도 | 등록 시간 | 줍깅 완료 여부 */
      zones = data.rows.map(function(r) {
        return {
          name: r["지역 이름"],
          lat: parseFloat(r["위도"]),
          lng: parseFloat(r["경도"]),
          regTime: r["등록 시간"],
          done: String(r["줍깅 완료 여부"]) === "true" || r["줍깅 완료 여부"] === "완료" || r["줍깅 완료 여부"] === true
        };
      }).filter(function(z){ return z.name && !isNaN(z.lat) && !isNaN(z.lng); });
      toast("구글 시트에서 " + zones.length + "개 구역을 불러왔습니다.");
    } catch (e) {
      zones = JSON.parse(JSON.stringify(DEMO_ZONES));
      toast("서버 연결 실패 — 데모 데이터로 실행합니다.");
    }
  } else {
    zones = JSON.parse(JSON.stringify(DEMO_ZONES));
  }
  drawMarkers();
}
function postToApi(payload) {
  if (!API_URL) return;
  /* Content-Type을 text/plain으로 보내면 CORS 사전요청(preflight)이 생기지 않습니다 */
  fetch(API_URL, { method: "POST", headers: { "Content-Type": "text/plain" }, body: JSON.stringify(payload) })
    .catch(function(){ /* 실패해도 앱은 계속 동작 */ });
}

/* ============================================================
   포인트 상점
   ============================================================ */
function openShop() {
  renderCatTabs();
  renderShop();
  openModal("shopModal");
}
function renderCatTabs() {
  const box = document.getElementById("catTabs");
  box.innerHTML = "";
  Object.keys(SHOP_ITEMS).forEach(function(cat) {
    const b = document.createElement("button");
    b.className = "cat-tab" + (cat === currentCat ? " active" : "");
    b.textContent = cat;
    b.onclick = function() { currentCat = cat; renderCatTabs(); renderShop(); };
    box.appendChild(b);
  });
}
function renderShop() {
  const list = document.getElementById("shopList");
  const bought = LS.get("purchases", {});
  list.innerHTML = "";
  SHOP_ITEMS[currentCat].forEach(function(item) {
    const count = bought[item.id] || 0;
    const soldOut = count >= item.limit;
    const div = document.createElement("div");
    div.className = "shop-item";
    div.innerHTML =
      '<div><div class="name">' + item.name + '</div>' +
      '<div class="price">' + item.point.toLocaleString() + 'P' +
      '<span class="real-price">(정가 ' + item.real.toLocaleString() + '원)</span></div>' +
      '<div class="limit">구매 제한: ' + count + ' / ' + item.limit + '개</div></div>';
    const btn = document.createElement("button");
    btn.className = "buy-btn";
    btn.textContent = soldOut ? "구매 한도 도달" : "구매";
    btn.disabled = soldOut || points < item.point;
    if (!soldOut && points < item.point) btn.textContent = "포인트 부족";
    btn.onclick = function() { buyItem(item); };
    div.appendChild(btn);
    list.appendChild(div);
  });
}
function buyItem(item) {
  const bought = LS.get("purchases", {});
  const count = bought[item.id] || 0;
  if (count >= item.limit) { toast("이 품목은 1인당 " + item.limit + "개까지만 구매할 수 있어요."); return; }
  if (points < item.point) { toast("포인트가 부족합니다."); return; }
  points -= item.point;
  bought[item.id] = count + 1;
  LS.set("points", points);
  LS.set("purchases", bought);
  renderPoints();
  renderShop();
  toast(" 「" + item.name + "」 구매 완료! (-" + item.point + "P)");
}

/* ============================================================
   랭킹 (일간/주간/월간/연간) + 주간·월간 보너스
   ============================================================ */
function myPeriodSec(tab) {
  if (tab === "일간") return getDaily().sec;
  if (tab === "주간") return getPeriod("week", weekId).sec;
  if (tab === "월간") return getPeriod("month", monthId).sec;
  return getPeriod("year", yearId).sec;
}
function buildRanking(tab) {
  const rows = DEMO_RANKINGS[tab].map(function(r){ return { name: r[0], sec: r[1], me: false }; });
  rows.push({ name: "나 (게스트)", sec: myPeriodSec(tab), me: true });
  rows.sort(function(a, b){ return b.sec - a.sec; });
  return rows;
}
function openRanking() {
  renderRankTabs();
  renderRanking();
  checkRankBonus();
  openModal("rankModal");
}
function renderRankTabs() {
  const box = document.getElementById("rankTabs");
  box.innerHTML = "";
  ["일간","주간","월간","연간"].forEach(function(tab) {
    const b = document.createElement("button");
    b.className = "cat-tab" + (tab === currentRankTab ? " active" : "");
    b.textContent = tab;
    b.onclick = function() { currentRankTab = tab; renderRankTabs(); renderRanking(); };
    box.appendChild(b);
  });
}
function renderRanking() {
  const list = document.getElementById("rankList");
  const rows = buildRanking(currentRankTab);
  const medals = ["1","2","3"];
  list.innerHTML = "";
  rows.forEach(function(r, i) {
    const div = document.createElement("div");
    div.className = "rank-row" + (r.me ? " me" : "");
    div.innerHTML =
      '<span><span class="rank-medal">' + (medals[i] || (i+1) + "위") + '</span> ' + r.name + '</span>' +
      '<span>' + fmtHMS(r.sec) + '</span>';
    list.appendChild(div);
  });
}
/* 주간/월간 순위권(1~3위) 보너스: 기간마다 1번만 지급 */
function checkRankBonus() {
  [["주간", WEEKLY_BONUS, "bonus_week_", weekId()], ["월간", MONTHLY_BONUS, "bonus_month_", monthId()]].forEach(function(cfg) {
    const tab = cfg[0], table = cfg[1], key = cfg[2] + cfg[3];
    if (LS.get(key, false)) return;
    const rows = buildRanking(tab);
    const myRank = rows.findIndex(function(r){ return r.me; });
    if (myRank >= 0 && myRank < 3 && rows[myRank].sec > 0) {
      const bonus = table[myRank];
      points += bonus;
      LS.set("points", points);
      LS.set(key, true);
      renderPoints();
      toast( tab + " 랭킹 " + (myRank+1) + "위 보너스 +" + bonus + "P 지급!");
    }
  });
}

/* ============================================================
   파티 (목록 / 참가 / 생성 + 금지어 필터)
   ============================================================ */
function getParties() {
  let p = LS.get("parties", null);
  if (!p) { p = JSON.parse(JSON.stringify(DEMO_PARTIES)); LS.set("parties", p); }
  return p;
}
function renderParties() {
  const parties = getParties();
  const joined = LS.get("joinedParties", []);
  const myBox = document.getElementById("myPartyList");
  const openBox = document.getElementById("openPartyList");
  myBox.innerHTML = ""; openBox.innerHTML = "";

  parties.forEach(function(p) {
    const isMine = joined.indexOf(p.id) !== -1;
    const div = document.createElement("div");
    div.className = "party-card";
    div.innerHTML = '<div><div class="p-name">' + p.name + '</div>' +
      '<div class="p-info"> ' + p.members + '명 · ' + p.zone + '</div></div>';
    const btn = document.createElement("button");
    btn.className = "buy-btn";
    if (isMine) {
      btn.textContent = "탈퇴";
      btn.style.background = "#ff6b6b";
      btn.onclick = function() { leaveParty(p.id); };
      div.appendChild(btn);
      myBox.appendChild(div);
    } else {
      btn.textContent = "참가";
      btn.onclick = function() { joinParty(p.id); };
      div.appendChild(btn);
      openBox.appendChild(div);
    }
  });
  if (!myBox.children.length)  myBox.innerHTML  = '<div style="font-size:12px;color:#999;padding:6px;">아직 참가한 파티가 없어요.</div>';
  if (!openBox.children.length) openBox.innerHTML = '<div style="font-size:12px;color:#999;padding:6px;">참가할 수 있는 파티가 없어요.</div>';
}
function joinParty(id) {
  const joined = LS.get("joinedParties", []);
  if (joined.indexOf(id) === -1) joined.push(id);
  LS.set("joinedParties", joined);
  const parties = getParties();
  const p = parties.find(function(x){ return x.id === id; });
  if (p) { p.members++; LS.set("parties", parties); }
  renderParties();
  toast("파티에 참가했어요!");
}
function leaveParty(id) {
  let joined = LS.get("joinedParties", []);
  joined = joined.filter(function(x){ return x !== id; });
  LS.set("joinedParties", joined);
  const parties = getParties();
  const p = parties.find(function(x){ return x.id === id; });
  if (p && p.members > 0) { p.members--; LS.set("parties", parties); }
  renderParties();
  toast("파티에서 탈퇴했어요.");
}
function isBadName(name) {
  const lower = name.toLowerCase().replace(/\s/g, "");
  return BAD_WORDS.some(function(w){ return lower.indexOf(w) !== -1; });
}
function createParty() {
  const input = document.getElementById("newPartyName");
  const name = input.value.trim();
  if (name.length < 2) { toast("파티 이름은 2글자 이상 입력해주세요."); return; }
  if (isBadName(name)) { toast("부적절한 단어가 포함된 파티명은 사용할 수 없어요."); return; }
  const parties = getParties();
  if (parties.some(function(p){ return p.name === name; })) { toast("이미 같은 이름의 파티가 있어요."); return; }
  const newParty = { id: Date.now(), name: name, members: 1, zone: selectedZone || "미정" };
  parties.push(newParty);
  LS.set("parties", parties);
  const joined = LS.get("joinedParties", []);
  joined.push(newParty.id);
  LS.set("joinedParties", joined);
  input.value = "";
  renderParties();
  toast("파티 「" + name + "」 생성 완료! 자동으로 참가되었어요.");
}

