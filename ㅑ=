      <button class="buy-btn" onclick="createParty()">생성</button>
    </div>
  </div>
</div>

<!-- ===================== 인증 사진 모달 ===================== -->
<div class="modal-back" id="verifyModal">
  <div class="modal">
    <h2> 줍깅 인증</h2>
    <div class="verify-box">
      줍깅 시간 조작 방지를 위해 <b>활동 종료 후 1시간 이내</b>에 줍깅 인증 사진을 등록해야
      포인트가 지급됩니다.<br>
      이번 활동 시간: <b id="verifyDuration">-</b><br>
      남은 인증 시간: <b id="verifyRemain">-</b>
    </div>
    <input type="file" id="photoInput" accept="image/*" onchange="previewPhoto()">
    <img id="photoPreview" alt="인증 사진 미리보기">
    <button class="primary-btn" id="verifyBtn" onclick="submitVerification()" disabled>인증하고 포인트 받기</button>
    <button class="primary-btn" style="background:#999" onclick="cancelVerification()">나중에 하기 (헤더에서 다시 열 수 있음)</button>
  </div>
</div>

<!-- ===================== 후원 모달 ===================== -->
<div class="modal-back" id="donateModal">
  <div class="modal">
    <button class="modal-close" onclick="closeModal('donateModal')">✕</button>
    <h2> 서비스 후원하기</h2>
    <p style="font-size:13px; line-height:1.6; color:#555;">
      제주 가치줍깅은 정부·지방자치단체의 지원을 받지 않는 서비스입니다.<br>
      여러분의 후원이 깨끗한 제주 바다를 만듭니다. 
    </p>
    <div class="donate-account" id="donateAccountText"></div>
    <button class="buy-btn" style="width:100%" onclick="copyAccount()">계좌번호 복사</button>
    <div style="margin-top:14px; font-size:12px; color:#777;">⚙ 후원 계좌 설정 (운영자용)</div>
    <input type="text" id="accountInput" class="small-input" placeholder="예: 제주은행 123-456-789012 (제주가치줍깅)">
    <button class="primary-btn" style="background:#4a7de0" onclick="saveAccount()">계좌 저장</button>
  </div>
</div>

<!-- ===================== 게스트 안내 모달 ===================== -->
